  "info": {
    "_postman_id": "d815be6d-560a-444e-b7ff-cb2e353d1fa6",
    "name": "Shodan Streaming API",
    "description": "The Shodan Streaming API delivers a real-time firehose of banner data collected by Shodan. Filtered streams are available by ASN, country, port, and CVE. Output is delivered either as newline-separated JSON or Server-Sent Events.\n\nContact Support:\n Name: Shodan Support\n Email: support@shodan.io",
